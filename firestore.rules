rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Check if the current user is an Admin
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'urbanadmin01@gmail.com';
    }

    // Explicit rules for users
    match /users/{userId} {
      allow read, write: if isAdmin() || (request.auth != null && request.auth.uid == userId);
    }
    
    // Explicit rules for addresses
    match /addresses/{addressId} {
      allow read, write: if isAdmin() || request.auth != null;
    }

    // Explicit rules for vendors
    match /vendors/{vendorId} {
      allow read: if true;
      allow write: if isAdmin() || (request.auth != null && request.auth.uid == vendorId);
    }

    // Explicit rules for services
    match /services/{serviceId} {
      allow read: if true;
      allow write: if isAdmin() || request.auth != null;
    }

    // Explicit rules for category requests
    match /category_requests/{requestId} {
      allow read: if isAdmin(); 
      allow create: if request.auth != null;
      allow update, delete: if isAdmin();
    }

    // Explicit rules for bookings
    match /bookings/{bookingId} {
      allow read, write: if isAdmin() || request.auth != null;
    }

    // Explicit rules for reviews
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if isAdmin() || (request.auth != null && request.auth.uid == resource.data.userId);
    }

    // Admins collection rule
    match /admins/{adminId} {
      allow read: if isAdmin() || (request.auth != null && request.auth.uid == adminId);
      allow write: if false; // Must be added manually via Firebase Console
    }

    // Default rule for all other documents
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
